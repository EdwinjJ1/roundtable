NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-local-secret

# Production auth. Create an OAuth client in Google Cloud Console and add:
# - http://localhost:3000/api/auth/callback/google for local dev
# - https://your-domain.com/api/auth/callback/google for production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Local-only fallback. Do not enable in production.
# When Google OAuth is not configured, non-production dev mode exposes a
# developer email sign-in so the product can still be exercised locally.
# ROUNDTABLE_ENABLE_DEV_AUTH=1

# Local JSON store. Defaults to ./.roundtable/data.json.
ROUNDTABLE_DATA_PATH=

# Persistence. Leave unset for local JSON. For production, use the normalized
# Postgres store so users, workbenches, chats, messages, skills, memory, turns,
# and missions are written to separate queryable tables.
# ROUNDTABLE_STORE_DRIVER=json
# ROUNDTABLE_STORE_DRIVER=postgres_normalized
# DATABASE_URL=postgres://roundtable:roundtable@localhost:5432/roundtable
# ROUNDTABLE_STORE_KEY=default
# ROUNDTABLE_POSTGRES_POOL_SIZE=10

# Agent dispatch. local-dispatch is deterministic for devrt and CI.
ROUNDTABLE_AGENT_ADAPTER=local-dispatch
# External local CLIs are powerful and should stay off in production unless the
# workspace is isolated. Set these only for trusted local development.
# Per-agent runtimes (claude-code, claude-code-router, codex, opencode) are
# configured in the Agent CLI console; ROUNDTABLE_AGENT_COMMAND/_ARGS only
# choose the CLI run inside the E2B sandbox adapter.
# ROUNDTABLE_ENABLE_EXTERNAL_AGENT=1
# ROUNDTABLE_AGENT_ADAPTER=agent-cli
ROUNDTABLE_AGENT_TIMEOUT_MS=120000
# Optional output-token ceiling per chat-model call. Leave unset to use the
# provider's own limit. Length-cut responses are auto-continued and stitched;
# ROUNDTABLE_MODEL_MAX_CONTINUATIONS caps those extra rounds (default 2).
# ROUNDTABLE_MODEL_MAX_TOKENS=
# ROUNDTABLE_MODEL_MAX_CONTINUATIONS=2
# Planning meetings always happen before CLI/Claude Code dispatch. When a model
# provider is configured, this optional override lets the meeting use a cheaper
# model while implementation keeps the provider's normal model. Set to "local"
# for the bounded deterministic fallback.
# ROUNDTABLE_PLANNING_MEETING_MODEL=

# Production workspaces are rooted under ROUNDTABLE_WORKSPACE_ROOT. Custom
# per-workbench paths are ignored in production unless explicitly enabled.
# ROUNDTABLE_WORKSPACE_ROOT=.roundtable/workspaces
# ROUNDTABLE_ALLOW_CUSTOM_WORKSPACE_PATH=0

# Optional per-agent / per-role runtime overrides (claude-code,
# claude-code-router, codex, opencode).
# ROUNDTABLE_AGENT_RUNTIME=claude-code
# ROUNDTABLE_AGENT_RUNTIME_ATLAS=codex

# DAG scheduler — max review→fix rounds per failed branch (default 2).
ROUNDTABLE_MAX_FIX_ROUNDS=2

# Safety scan of agent artifacts (secrets + dangerous code). Default on.
# Set to false only for testing.
ROUNDTABLE_SAFETY_ENABLED=true

# E2B sandbox (opt-in). Set ROUNDTABLE_AGENT_ADAPTER=e2b to run agent CLIs inside
# an E2B sandbox. If the key is missing, dispatch logs a warning and falls back
# to local-dispatch.
E2B_API_KEY=

# MiniMax real model (opt-in). Set ROUNDTABLE_AGENT_ADAPTER=minimax to run agents
# against the MiniMax chat API. If the key is missing, dispatch falls back to
# local-dispatch (surfaced as a task event). China endpoint shown; international
# is https://api.minimax.io/v1.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3
